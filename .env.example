# ===== Supabase =====
SUPABASE_URL=                      # http://127.0.0.1:54321 for local dev
SUPABASE_ANON_KEY=                 # anon key (clients)
SUPABASE_SERVICE_ROLE_KEY=         # Edge Functions only — never ship to clients

# Next.js apps read the public pair with the NEXT_PUBLIC_ prefix
# (apps/web/.env.local and apps/admin/.env.local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Flutter gets the same pair via --dart-define=SUPABASE_URL=...,SUPABASE_ANON_KEY=...

# ===== Agora (video) — Phase 5 =====
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ===== Eskiz.uz (SMS) — Phase 1 uses SMS_MODE=mock, real creds for Phase 9 =====
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
SMS_MODE=mock                      # mock = OTP code printed to function logs | live = send via Eskiz

# ===== Payme — Phase 4 =====
PAYME_MERCHANT_ID=
PAYME_KEY=
PAYME_TEST_KEY=                    # sandbox key

# ===== Click — Phase 4 =====
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# ===== Uzum — Phase 4 =====
UZUM_MERCHANT_ID=
UZUM_SECRET=

# ===== Firebase Cloud Messaging — Phase 9 =====
FCM_SERVICE_ACCOUNT_JSON=          # one-line JSON of the service account

# ===== Modes =====
PAYMENTS_MODE=test                 # test = mock webhooks allowed | live
APP_BASE_URL=http://localhost:3000 # public web URL (deep links, checkout redirects)
